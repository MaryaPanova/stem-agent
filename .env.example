# Provider: 'openai' or 'anthropic' (default: anthropic)
STEM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
STEM_MODEL=gpt-4o

# Anthropic (uncomment and set STEM_PROVIDER=anthropic to switch)
# ANTHROPIC_API_KEY=sk-ant-...
# STEM_MODEL=claude-sonnet-4-6

STEM_CHECKPOINT_DIR=./checkpoints
STEM_PLAYBOOK_DIR=./playbooks
